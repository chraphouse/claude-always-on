# Claude Always-On Agent Configuration
# Copy this file to config.env and fill in your details

# === Agent Email (the email Claude monitors) ===
AGENT_EMAIL="your-agent-email@yahoo.com"
AGENT_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# === Your Personal Email (where you send instructions from) ===
PERSONAL_EMAIL="your-email@gmail.com"

# === Email Server Settings ===
# Auto-detected for Yahoo and Gmail. Set manually for other providers.
IMAP_SERVER="imap.mail.yahoo.com"
IMAP_PORT=993
SMTP_SERVER="smtp.mail.yahoo.com"
SMTP_PORT=465

# === Optional Settings ===
# Check interval in seconds (default: 180 = 3 minutes)
CHECK_INTERVAL=180

# Folders to check for emails (comma-separated)
CHECK_FOLDERS="INBOX,Bulk"

# Max email body length to process (characters)
MAX_BODY_LENGTH=2000
